# Quicksilver frontend (Vite) configuration template.
# Copy to `.env` for local development. NEVER commit a real `.env`.
# All Vite-exposed vars MUST start with VITE_.

# Base URL for the Quicksilver backend API.
# Leave empty in dev to use Vite's /api proxy → VITE_API_PROXY_TARGET.
# In production, set this to the deployed backend origin, e.g.:
#   VITE_API_BASE_URL=https://api.quicksilver.example.com
VITE_API_BASE_URL=

# Dev-only: where the /api proxy forwards. Defaults to http://localhost:8080
# when running `npm run dev` if not set.
VITE_API_PROXY_TARGET=http://localhost:8080
