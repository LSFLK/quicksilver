# Handa server configuration template.
# Copy to `.env` for local development. NEVER commit a real `.env`.
# In production, inject these as real environment variables via your
# orchestrator (Docker / systemd / Kubernetes / Vercel envs / etc.).

# --- HTTP ---
HANDA_PORT=8080
HANDA_ALLOWED_ORIGINS=http://localhost:3000

# --- Auth ---
# 32+ char random string. Generate with: openssl rand -base64 48
HANDA_JWT_SECRET=replace-with-a-long-random-string-of-at-least-32-chars
HANDA_JWT_TTL=24h

# --- Sessions ---
# 32-byte AES-GCM key, hex-encoded (64 hex chars).
# Generate with: openssl rand -hex 32
HANDA_SESSION_SEAL_KEY=replace-with-64-hex-chars-from-openssl-rand-hex-32
HANDA_SESSION_IDLE_TTL=30m
HANDA_SESSION_SWEEP_INTERVAL=1m

# --- Upstream timeouts ---
HANDA_IMAP_TIMEOUT=30s
HANDA_SMTP_TIMEOUT=30s

# --- Rate limiting ---
HANDA_RATE_LIMIT_LOGIN_PER_MIN=10

# --- Observability ---
HANDA_LOG_LEVEL=info
HANDA_LOG_FORMAT=json

# --- TLS (optional; leave empty to serve plain HTTP behind a TLS-terminating proxy) ---
HANDA_TLS_CERT=
HANDA_TLS_KEY=

# --- HTTP server timeouts ---
HANDA_READ_HEADER_TIMEOUT=10s
HANDA_WRITE_TIMEOUT=60s
HANDA_IDLE_TIMEOUT=120s
HANDA_SHUTDOWN_TIMEOUT=15s
