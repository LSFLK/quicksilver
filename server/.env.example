# Quicksilver server configuration template.
# Copy to `.env` for local development. NEVER commit a real `.env`.
# In production, inject these as real environment variables via your
# orchestrator (Docker / systemd / Kubernetes / Vercel envs / etc.).

# --- HTTP ---
QUICKSILVER_PORT=8080
QUICKSILVER_ALLOWED_ORIGINS=http://localhost:3000

# --- Auth ---
# 32+ char random string. Generate with: openssl rand -base64 48
QUICKSILVER_JWT_SECRET=replace-with-a-long-random-string-of-at-least-32-chars
QUICKSILVER_JWT_TTL=24h

# --- Sessions ---
# 32-byte AES-GCM key, hex-encoded (64 hex chars).
# Generate with: openssl rand -hex 32
QUICKSILVER_SESSION_SEAL_KEY=replace-with-64-hex-chars-from-openssl-rand-hex-32
QUICKSILVER_SESSION_IDLE_TTL=30m
QUICKSILVER_SESSION_SWEEP_INTERVAL=1m

# --- Upstream timeouts ---
QUICKSILVER_IMAP_TIMEOUT=30s
QUICKSILVER_SMTP_TIMEOUT=30s

# --- Rate limiting ---
QUICKSILVER_RATE_LIMIT_LOGIN_PER_MIN=10

# --- Observability ---
QUICKSILVER_LOG_LEVEL=info
QUICKSILVER_LOG_FORMAT=json

# --- TLS (optional; leave empty to serve plain HTTP behind a TLS-terminating proxy) ---
QUICKSILVER_TLS_CERT=
QUICKSILVER_TLS_KEY=

# --- HTTP server timeouts ---
QUICKSILVER_READ_HEADER_TIMEOUT=10s
QUICKSILVER_WRITE_TIMEOUT=60s
QUICKSILVER_IDLE_TIMEOUT=120s
QUICKSILVER_SHUTDOWN_TIMEOUT=15s
